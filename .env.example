# ========== 数据库配置 ==========
# 开发环境使用SQLite，无需配置
# 生产环境切换为MySQL:
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/dwbijia
DATABASE_URL=sqlite+aiosqlite:///./dwbijia.db

# ========== Redis配置 ==========
REDIS_URL=redis://localhost:6379/0

# ========== JWT认证 ==========
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== 淘宝API配置 ==========
# 申请地址: https://open.taobao.com/
TAOBAO_API_KEY=
TAOBAO_API_SECRET=
TAOBAO_API_URL=

# ========== 得物API配置 ==========
# 如使用官方API，请在此填入
DEWU_API_KEY=
DEWU_API_SECRET=
DEWU_API_URL=

# ========== 通知配置 ==========
# 邮件
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 短信 (阿里云)
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# ========== 爬虫配置 ==========
# 请求间隔(秒)，遵守robots协议
CRAWL_DELAY=2
# 每小时最大请求数
MAX_REQUESTS_PER_HOUR=500
# User-Agent
USER_AGENT=Mozilla/5.0 (compatible; PriceBot/1.0; +http://example.com/bot)

# ========== 代理池配置（可选） ==========
# 付费代理API（快代理/芝麻代理/站大爷等）
# PROXY_API_URL=https://dps.kdlapi.com/api/getdps/?orderid=xxx&num=10&format=json
# PROXY_API_KEY=your-api-key
# 静态代理列表（逗号分隔）
# PROXY_LIST=http://ip1:port1,http://ip2:port2

# ========== 应用配置 ==========
APP_NAME=跨平台智能比价系统
DEBUG=true
HOST=0.0.0.0
PORT=8000
